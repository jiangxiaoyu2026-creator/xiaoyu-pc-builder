{
  "name": "xiaoyu-miniprogram",
  "version": "1.0.0",
  "private": true,
  "description": "小鱼装机微信小程序",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "dev:weapp": "taro build --type weapp --watch",
    "upload": "npm run build:weapp && node ci/upload.js",
    "preview": "npm run build:weapp && node ci/upload.js --preview"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "author": "xiaoyu",
  "dependencies": {
    "@tarojs/cli": "4.1.11",
    "@tarojs/components": "4.1.11",
    "@tarojs/helper": "4.1.11",
    "@tarojs/plugin-framework-react": "4.1.11",
    "@tarojs/plugin-platform-weapp": "4.1.11",
    "@tarojs/react": "4.1.11",
    "@tarojs/runtime": "4.1.11",
    "@tarojs/shared": "4.1.11",
    "@tarojs/taro": "4.1.11",
    "@tarojs/webpack5-runner": "4.1.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime": "^7.29.2",
    "@types/react": "^18.3.0",
    "babel-loader": "^10.1.1",
    "babel-preset-taro": "^4.1.11",
    "miniprogram-ci": "^2.1.31",
    "sass": "^1.77.0",
    "typescript": "^5.4.0",
    "webpack": "5.91.0"
  }
}
